# Ödeme (gerçek değerleri KULLANICI elle girer, asla AI'ya verilmez)
PROJECT_OWNER_NAME=your_name_here
PAYMENT_IBAN=your_iban_here
PAYMENT_BANK_NAME=your_bank_here

# Veritabanı
DATABASE_URL=your_neon_connection_string

# AI (Google Gemini - birincil, ücretsiz katman)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key

# AI (xAI Grok - yedek, ücretsiz deneme kredisi)
XAI_API_KEY=your_xai_api_key

# AI (Groq - yedek, ücretsiz: 30 RPM, 14.4K istek/gün)
GROQ_API_KEY=your_groq_api_key

# E-posta
RESEND_API_KEY=your_resend_api_key

# Faz 2 - PayTR
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt
PAYTR_SUCCESS_URL=https://yourdomain.com/odeme/success
PAYTR_FAIL_URL=https://yourdomain.com/odeme/fail
PAYTR_TEST_MODE=1

# Admin
ADMIN_PASSWORD=change_me
